# HYCU LMS Automation — Environment Variables
# Copy to .env and fill in values

# SSO Credentials
HYCU_USER_ID=
HYCU_USER_NAME=

# FIDO KeyStore
FIDO_KEY_ID=
FIDO_ALG=ecdsa
FIDO_PRIKEY=
FIDO_FINGERPRINT=
FIDO_MULTI=y
FIDO_TYPE=pin
FIDO_PIN=

# Full KeyStore JSON (cookie value for dreamsecurity/magicsa/keyStore)
FIDO_KEYSTORE_JSON=

# Dashboard sync (optional)
HYCU_DASHBOARD_URL=
HYCU_API_KEY=
