# ── Required ───────────────────────────────────────────────────────────────────
HYCU_USER_ID=
HYCU_USER_NAME=

# FIDO2 credentials (from HYCU portal registration)
FIDO_KEY_ID=
FIDO_ALG=
FIDO_PRIKEY=
FIDO_FINGERPRINT=
FIDO_MULTI=
FIDO_TYPE=
FIDO_PIN=
FIDO_KEYSTORE_JSON=

# ── Optional (auto-detected / has defaults) ───────────────────────────────────

# Academic semester — auto-detected from current date if omitted
# Month 3-8 → year=current, term=10 (1학기)
# Month 9-12 → year=current, term=20 (2학기)
# Month 1-2 → year=previous, term=20 (2학기)
# HYCU_YEAR=2026
# HYCU_SEMESTER=10

# Scheduler — default: weekdays 17:00 KST
# SCHEDULE_HOUR=17
# SCHEDULE_MINUTE=0

# Dashboard sync (best-effort, non-blocking)
# HYCU_DASHBOARD_URL=https://hycu.jclee.me
# HYCU_API_KEY=

# Service / Cloudflare container runtime
# HYCU_COOKIE_DIR=/tmp/hycu-cookies
# HYCU_SERVICE_API_KEY=
# PORT=8080
