{
  "name": "hycu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "HYCU LMS automation - lecture attendance via Playwright",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "login": "tsx src/index.ts login",
    "attend": "tsx src/index.ts attend",
    "status": "tsx src/index.ts status",
    "api-attend": "tsx src/index.ts api-attend",
    "dashboard:dev": "npm run dev --prefix web",
    "dashboard:deploy": "npm run deploy --prefix web",
    "push-cookies": "tsx scripts/push-cookies.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}
